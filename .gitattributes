# Default: auto-detect text files and normalize line endings
* text=auto

.gitattributes text eol=lf

# Dart / Flutter
*.dart text
*.arb text
*.yaml text
*.yml text eol=lf
*.json text
*.md text

# Shell scripts require LF
*.sh text eol=lf

# Windows batch files require CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
